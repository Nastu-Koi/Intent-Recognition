# ============================================================================
# 环境变量配置模板 (.env.example)
# ============================================================================
#
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填写下面的变量值
# 3. 根据场景选择对应的 API Key
# 4. 运行 Python 脚本时会自动加载这些变量
#
# ⚠️  重要：千万不要将包含真实 API Key 的 .env 文件提交到版本控制！
# ✅ .env 已在 .gitignore 中排除
#
# ============================================================================

# ============================================================================
# LLM 配置 (OpenAI-Compatible 统一格式)
# ============================================================================
# 所有 LLM 调用统一使用 ChatOpenAI，通过 base_url 切换供应商。
#
# 阿里云 Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI:      https://api.openai.com/v1
# DeepSeek:    https://api.deepseek.com/v1
# 本地 Ollama:  http://localhost:11434/v1
# ============================================================================

LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-max
# LLM_TEMPERATURE=0.0

# ============================================================================
# Dify 工具 API 配置
# ============================================================================
# Dify API Base URL
# 云端默认: https://api.dify.ai/v1
# 自建示例: http://your-dify-server/v1 或 http://your-dify-server/api/v1
DIFY_API_BASE_URL=https://api.dify.ai/v1

# Dify App 类型：chat 对应 /chat-messages，workflow 对应 /workflows/run
DIFY_APP_TYPE=chat

# Dify 请求超时时间（秒）
DIFY_TIMEOUT=90

# 全局 Dify App API Key：所有 agent 共用同一个 key 时使用
DIFY_API_KEY=your-dify-api-key-here

# ============================================================================
# Dify SubAgent 独立 API Key 配置
# 每个 SubAgent 对应一个独立的 Dify App，可以使用不同的 API Key
# 不配置时降级使用全局 DIFY_API_KEY
# ============================================================================

# dify_file_uploader — 上传文件到 Dify (调用 /files/upload 接口，使用全局 key)
# DIFY_DIFY_FILE_UPLOADER_API_KEY=your-file-uploader-dify-key

# dify_doc_summary — Dify 文档总结 Workflow App
DIFY_DIFY_DOC_SUMMARY_API_KEY=your-doc-summary-dify-app-key
# DIFY_DOC_SUMMARY_APP_TYPE=workflow   # workflow 或 chat (默认 workflow)

# dify_knowledge_qa — Dify 知识库问答 Chat App
DIFY_DIFY_KNOWLEDGE_QA_API_KEY=your-knowledge-qa-dify-app-key
# DIFY_KNOWLEDGE_QA_APP_TYPE=chat      # workflow 或 chat (默认 chat)

# dify_vision — Dify 图片识别 Vision App
DIFY_DIFY_VISION_API_KEY=your-vision-dify-app-key
# DIFY_VISION_APP_TYPE=chat            # workflow 或 chat (默认 chat)

# 文件上传用户标识
# DIFY_UPLOADER_USER=intent-recognition-uploader
